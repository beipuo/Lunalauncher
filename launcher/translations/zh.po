msgctxt "Nide8AuthPage"
msgid "About nide8auth"
msgstr "关于 nide8auth"

msgctxt "Nide8AuthPage"
msgid "<html><head/><body><p>nide8auth is a Java agent required for UnifiedPass authentication to work with Minecraft. It allows the game to authenticate against UnifiedPass servers.</p><p>It is automatically downloaded when you launch a game with a UnifiedPass account, but you can also manage it here.</p><p>For more information, visit <a href=\"https://login.mc-user.com:233/\">login.mc-user.com:233</a></p></body></html>"
msgstr "<html><head/><body><p>nide8auth 是 Minecraft 使用 UnifiedPass 认证所需的 Java 代理。它允许游戏向 UnifiedPass 服务器进行认证。</p><p>使用 UnifiedPass 账号启动游戏时会自动下载，但您也可以在此处管理它。</p><p>更多信息请访问 <a href=\"https://login.mc-user.com:233/\">login.mc-user.com:233</a></p></body></html>"

msgctxt "Nide8AuthPage"
msgid "Usage"
msgstr "使用方法"

msgctxt "Nide8AuthPage"
msgid "<html><head/><body><p>nide8auth is automatically used when launching a game with a UnifiedPass account. The following JVM arguments will be added:</p></body></html>"
msgstr "<html><head/><body><p>使用 UnifiedPass 账号启动游戏时会自动使用 nide8auth。将添加以下 JVM 参数：</p></body></html>"

